{
  "public": true,
  "functions": {
    "api/**/*.[jt]s": {
      "runtime": "vercel-deno@3.1.1",
      "maxDuration": 5
    }
  },
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "username"
        }
      ],
      "destination": "/api/"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/api/$1"
    }
  ]
}
